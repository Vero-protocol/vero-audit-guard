{
  "name": "@vero/audit-guard-policy-engine",
  "version": "1.0.0",
  "description": "OPA-based Policy as Code engine for PR compliance checks",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "evaluate": "ts-node src/cli.ts",
    "check-pr": "ts-node src/cli.ts pr",
    "gen-docs:fv": "python3 scripts/generate-fv-report.py"
  },
  "keywords": [
    "opa",
    "policy-as-code",
    "security",
    "pr-compliance",
    "vero"
  ],
  "author": "Vero Security Team",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "typescript": "^5.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
